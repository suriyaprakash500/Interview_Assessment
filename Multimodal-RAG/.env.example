# Qwen-VL API Settings
# Support for OpenAI-compatible services like OpenRouter, Together AI, or Alibaba DashScope.
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://openrouter.ai/api/v1
# Alternative Bases:
# - DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# - Together AI: https://api.together.xyz/v1
QWEN_MODEL=qwen/qwen-2.5-vl-72b-instruct
# Alternative Models:
# - DashScope: qwen-vl-max or qwen-vl-plus
# - Together AI: Qwen/Qwen2.5-VL-72B-Instruct

# Embedding Strategy Configuration
# Options: 'local' (offline using Sentence-Transformers) or 'openai' (uses OpenAI API)
EMBEDDING_PROVIDER=local
# Required if EMBEDDING_PROVIDER is 'openai'
OPENAI_API_KEY=

# Ingestion Pipeline Run Options
# Set to 'true' to run visual captioning in mock mode (doesn't call Qwen-VL, useful for quick dry-runs)
MOCK_MODE=false
